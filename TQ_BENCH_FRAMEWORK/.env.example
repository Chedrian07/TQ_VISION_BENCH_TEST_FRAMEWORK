# --- OPENAI COMPATIBLE API SERVER CONFIGURATION --- #

OPENAI_API_KEY="api"
OPENAI_BASE_URL="http://localhost:8000/v1"
HF_TOKEN=""

# Client timeouts / retries
TQ_BENCH_REQUEST_TIMEOUT_SECONDS=600
TQ_BENCH_RELOAD_TIMEOUT_SECONDS=60
TQ_BENCH_CONNECT_TIMEOUT_SECONDS=10
TQ_BENCH_MAX_RETRIES=2

# Benchmark dataset JSONL files
# Each file should use the unified schema documented in README.md.
TEXTVQA_DATASET_FILE="/abs/path/to/textvqa.jsonl"
CHARTQA_DATASET_FILE="/abs/path/to/chartqa.jsonl"
AI2D_DATASET_FILE="/abs/path/to/ai2d.jsonl"
DOCVQA_DATASET_FILE="/abs/path/to/docvqa.jsonl"
MATHVISTA_DATASET_FILE="/abs/path/to/mathvista.jsonl"
MMMU_DATASET_FILE="/abs/path/to/mmmu.jsonl"
OCRBENCH_V2_DATASET_FILE="/abs/path/to/ocrbench_v2.jsonl"
CHARTQAPRO_DATASET_FILE="/abs/path/to/chartqapro.jsonl"
