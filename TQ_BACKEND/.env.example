# Network / auth
TQ_HOST=0.0.0.0
TQ_PORT=8000
TQ_API_KEY=api
TQ_LOG_LEVEL=INFO

# Model loading
TQ_MODEL=mlx-community/Qwen3.5-0.8B-MLX-bf16
TQ_ADAPTER_PATH=
TQ_REVISION=main
TQ_TRUST_REMOTE_CODE=false
TQ_PRELOAD_MODEL=true

# Qwen3.5 benchmark policy
# This backend is intentionally non-thinking only.
TQ_FORCE_DISABLE_THINKING=true

# Sampling profile
# controlled | best_effort_general | best_effort_reasoning
TQ_SAMPLING_PROFILE=controlled
TQ_DEFAULT_MAX_OUTPUT_TOKENS=512
TQ_DEFAULT_REPETITION_CONTEXT_SIZE=20
TQ_DEFAULT_PRESENCE_CONTEXT_SIZE=20
TQ_PREFILL_STEP_SIZE=2048

# Controlled benchmark profile
TQ_CONTROLLED_TEMPERATURE=0.0
TQ_CONTROLLED_TOP_P=1.0
TQ_CONTROLLED_TOP_K=0
TQ_CONTROLLED_MIN_P=0.0
TQ_CONTROLLED_PRESENCE_PENALTY=
TQ_CONTROLLED_REPETITION_PENALTY=

# Best-effort profile: general tasks
# Qwen3.5 instruct non-thinking recommendation
TQ_BEST_EFFORT_GENERAL_TEMPERATURE=0.7
TQ_BEST_EFFORT_GENERAL_TOP_P=0.8
TQ_BEST_EFFORT_GENERAL_TOP_K=20
TQ_BEST_EFFORT_GENERAL_MIN_P=0.0
TQ_BEST_EFFORT_GENERAL_PRESENCE_PENALTY=1.5
TQ_BEST_EFFORT_GENERAL_REPETITION_PENALTY=

# Best-effort profile: reasoning-style tasks, still with thinking disabled
TQ_BEST_EFFORT_REASONING_TEMPERATURE=1.0
TQ_BEST_EFFORT_REASONING_TOP_P=0.95
TQ_BEST_EFFORT_REASONING_TOP_K=20
TQ_BEST_EFFORT_REASONING_MIN_P=0.0
TQ_BEST_EFFORT_REASONING_PRESENCE_PENALTY=1.5
TQ_BEST_EFFORT_REASONING_REPETITION_PENALTY=

# KV cache quantization
# Scheme: none | mlx | turboquant
# Allowed mlx bits: 2, 3, 4
# Allowed turboquant bits: 2, 2.5, 3, 3.5, 4
TQ_KV_QUANT_SCHEME=turboquant
TQ_KV_BITS=3.5
TQ_KV_GROUP_SIZE=64
TQ_QUANTIZED_KV_START=5000

# TurboQuant-specific settings
TQ_TURBOQUANT_SEED=0
TQ_TURBOQUANT_FROM_FIRST_TOKEN=true
